{
  "expo": {
    "name": "힐링로드",
    "slug": "healingroad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D7D6F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.donebystudio.healingroad"
    },
    "android": {
      "package": "com.donebystudio.healingroad",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D7D6F"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "힐링로드가 주변 웰니스 여행지를 찾기 위해 위치 정보를 사용합니다."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9859685900931020~6661294302"
        }
      ]
    ],
    "scheme": "healingroad",
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/healingroad"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ce40274-23ce-4512-b0d0-36c83c400dc8"
      }
    }
  }
}
